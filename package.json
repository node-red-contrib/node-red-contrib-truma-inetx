{
  "name": "node-red-contrib-truma-inetx",
  "version": "0.0.1",
  "description": "Reverse engineering tools and Node.js BLE probe for Truma iNet X.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "truma-inetx": "./bin/truma-inetx.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "tsc -p tsconfig.json --build --clean",
    "read": "npm run build --silent && node ./bin/truma-inetx.js read",
    "check": "npm run build",
    "test": "npm run build && node --test"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "cbor-x": "^1.6.4"
  },
  "overrides": {
    "tar": "^7.5.13"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^6.0.3"
  }
}
