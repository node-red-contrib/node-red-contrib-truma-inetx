{
  "name": "node-red-contrib-truma-inetx",
  "version": "0.0.1",
  "description": "Node.js BLE Lib, Cli and nodered device for Truma iNet X.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/node-red-contrib/node-red-contrib-truma-inetx/"
  },
  "bugs": {
    "url": "https://github.com/node-red-contrib/node-red-contrib-truma-inetx/issues"
  },
  "homepage": "https://github.com/node-red-contrib/node-red-contrib-truma-inetx#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "truma-inetx": "bin/truma-inetx.js"
  },
  "node-red": {
    "version": ">=3.1.0",
    "nodes": {
      "truma-inetx-device": "nodes/truma-inetx-device.js",
      "truma-inetx-get": "nodes/truma-inetx-get.js",
      "truma-inetx-set": "nodes/truma-inetx-set.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "tsc -p tsconfig.json --build --clean",
    "discover": "npm run build --silent && node ./bin/truma-inetx.js discover",
    "get": "npm run build --silent && node ./bin/truma-inetx.js get",
    "pair": "npm run build --silent && node ./bin/truma-inetx.js pair",
    "set": "npm run build --silent && node ./bin/truma-inetx.js set",
    "lint": "eslint .",
    "check": "npm run build && npm run lint && npm test",
    "test": "npm run build && node --test"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "cbor-x": "^1.6.4",
    "commander": "^15.0.0",
    "dbus-next": "^0.10.2"
  },
  "overrides": {
    "tar": "^7.5.13"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "keywords": [
    "node-red",
    "truma",
    "inetx",
    "bluetooth",
    "ble"
  ],
  "license": "MIT"
}
